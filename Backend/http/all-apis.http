# Dev Hube — All APIs (NestJS {{baseUrl}} + Python workers)
# Environment: status bar → dev | Config: http-client.env.json

# ═══════════════════════════════════════════════════════════════
# HEALTH
# ═══════════════════════════════════════════════════════════════

### API health
GET {{baseUrl}}/health
Accept: application/json

###

# ═══════════════════════════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════════════════════════

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}",
  "name": "Test User"
}

###

### Login
# @name userLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

###

@userToken = {{userLogin.response.body.accessToken}}

### Me (JWT)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{userToken}}

###

### Admin login
# @name adminLogin
POST {{baseUrl}}/auth/admin/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

###

@adminToken = {{adminLogin.response.body.accessToken}}

### Admin me
GET {{baseUrl}}/auth/admin/me
Authorization: Bearer {{adminToken}}

###

# ═══════════════════════════════════════════════════════════════
# TOOLS (PUBLIC)
# ═══════════════════════════════════════════════════════════════

### List tools
GET {{baseUrl}}/tools

###

### List tools — category
GET {{baseUrl}}/tools?category=PDF

###

### List tools — search
GET {{baseUrl}}/tools?search=qr

###

### List tools — featured
GET {{baseUrl}}/tools?featured=true

###

### Tool by slug
GET {{baseUrl}}/tools/temp-mail

###

### Categories
GET {{baseUrl}}/categories

###

# ═══════════════════════════════════════════════════════════════
# TEMP MAIL
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/temp-mail/health

###

### Domains
GET {{baseUrl}}/temp-mail/domains

###

### Create mailbox
# @name createMailbox
POST {{baseUrl}}/temp-mail/mailboxes
Content-Type: application/json

{}

###

### Create mailbox — custom
POST {{baseUrl}}/temp-mail/mailboxes
Content-Type: application/json

{
  "localPart": "john.test",
  "domain": "virgilian.com"
}

###

@mailboxId = {{createMailbox.response.body.id}}

### Get mailbox
GET {{baseUrl}}/temp-mail/mailboxes/{{mailboxId}}

###

### List messages
GET {{baseUrl}}/temp-mail/mailboxes/{{mailboxId}}/messages

###

### Message detail
GET {{baseUrl}}/temp-mail/mailboxes/{{mailboxId}}/messages/{{messageId}}

###

### Delete mailbox
DELETE {{baseUrl}}/temp-mail/mailboxes/{{mailboxId}}

###

# ═══════════════════════════════════════════════════════════════
# QR CODE GENERATOR
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/qr-generator/health

###

### Create static QR
# @name qrStatic
POST {{baseUrl}}/qr-generator/codes
Content-Type: application/json

{
  "mode": "static",
  "contentType": "url",
  "payload": "https://mbstack.net/",
  "foregroundColor": "#000000",
  "backgroundColor": "#ffffff",
  "errorCorrection": "H",
  "sizePx": 512
}

###

### Create static + track scans
# @name qrTracked
POST {{baseUrl}}/qr-generator/codes
Content-Type: application/json

{
  "mode": "static",
  "contentType": "url",
  "payload": "https://example.com",
  "trackScans": true,
  "foregroundColor": "#1a1a2e",
  "backgroundColor": "#ffffff",
  "errorCorrection": "H",
  "sizePx": 512
}

###

@qrCodeId = {{qrTracked.response.body.id}}
@qrShortCode = {{qrTracked.response.body.shortCode}}

### Create dynamic QR
# @name qrDynamic
POST {{baseUrl}}/qr-generator/codes
Content-Type: application/json

{
  "mode": "dynamic",
  "contentType": "url",
  "payload": "https://google.com",
  "foregroundColor": "#000000",
  "backgroundColor": "#ffffff",
  "errorCorrection": "H",
  "sizePx": 512
}

###

### Get QR
GET {{baseUrl}}/qr-generator/codes/{{qrCodeId}}

###

### Regenerate image
GET {{baseUrl}}/qr-generator/codes/{{qrCodeId}}/image

###

### Update dynamic URL
PATCH {{baseUrl}}/qr-generator/codes/{{qrCodeId}}
Content-Type: application/json

{
  "payload": "https://github.com"
}

###

### Analytics
GET {{baseUrl}}/qr-generator/codes/{{qrCodeId}}/analytics

###

### Redirect (scan)
GET {{baseUrl}}/qr-generator/go/{{qrShortCode}}

###

### Delete QR
DELETE {{baseUrl}}/qr-generator/codes/{{qrCodeId}}

###

# ═══════════════════════════════════════════════════════════════
# IMAGE COMPRESSOR
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/image-compressor/health

###

### Compress (needs ./samples/photo.jpg)
POST {{baseUrl}}/image-compressor/compress?quality=82&maxWidth=1920&outputFormat=auto&stripMetadata=true
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="photo.jpg"
Content-Type: image/jpeg

< ./samples/photo.jpg
--B--

###

### Compress WebP
POST {{baseUrl}}/image-compressor/compress?quality=70&maxWidth=1280&outputFormat=webp&stripMetadata=true
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="photo.png"
Content-Type: image/png

< ./samples/photo.png
--B--

###

# ═══════════════════════════════════════════════════════════════
# PDF TO WORD
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/pdf-to-word/health

###

### Convert (needs ./samples/document.pdf)
POST {{baseUrl}}/pdf-to-word/convert
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

### Convert pages 1–3
POST {{baseUrl}}/pdf-to-word/convert?startPage=1&endPage=3
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

# ═══════════════════════════════════════════════════════════════
# MERGE PDF
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/merge-pdf/health

###

### Merge (needs ./samples/document.pdf — two parts)
POST {{baseUrl}}/merge-pdf/merge
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="files"; filename="part-a.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B
Content-Disposition: form-data; name="files"; filename="part-b.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

# ═══════════════════════════════════════════════════════════════
# SPLIT PDF
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/split-pdf/health

###

### Split range pages 1–2
POST {{baseUrl}}/split-pdf/split?mode=range&startPage=1&endPage=2
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

### Split every page (ZIP)
POST {{baseUrl}}/split-pdf/split?mode=each
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

### Inspect PDF (page count)
POST {{baseUrl}}/split-pdf/inspect
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

# ═══════════════════════════════════════════════════════════════
# COMPRESS PDF
# ═══════════════════════════════════════════════════════════════

### Health
GET {{baseUrl}}/compress-pdf/health

###

### Compress PDF
POST {{baseUrl}}/compress-pdf/compress?level=medium
Content-Type: multipart/form-data; boundary=B

--B
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./samples/document.pdf
--B--

###

