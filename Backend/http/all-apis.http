# ═══════════════════════════════════════════════════════════════
# ADMIN — TOOLS
# ═══════════════════════════════════════════════════════════════

### List tools
GET {{baseUrl}}/admin/tools
Authorization: Bearer {{adminToken}}

###

### List tools — query
GET {{baseUrl}}/admin/tools?category=Media&featured=true
Authorization: Bearer {{adminToken}}

###

### Get tool
GET {{baseUrl}}/admin/tools/qr-generator
Authorization: Bearer {{adminToken}}

###

### Create tool
POST {{baseUrl}}/admin/tools
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "slug": "demo-tool",
  "name": "Demo Tool",
  "tagline": "API test",
  "description": "Created from REST Client all-apis.http smoke test.",
  "category": "Formatting",
  "icon": "wrench",
  "accent": "violet",
  "status": "soon",
  "keywords": ["demo"],
  "featured": false
}

###

### Update tool
PATCH {{baseUrl}}/admin/tools/qr-generator
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "ready",
  "featured": true
}

###

### Delete tool
DELETE {{baseUrl}}/admin/tools/demo-tool
Authorization: Bearer {{adminToken}}

###

### Admin categories
GET {{baseUrl}}/admin/categories
Authorization: Bearer {{adminToken}}

###

### Bulk tools action
POST {{baseUrl}}/admin/tools/bulk
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "slugs": ["demo-tool"],
  "action": "delete"
}

###

### Get tool blog
GET {{baseUrl}}/admin/tools/qr-generator/blog
Authorization: Bearer {{adminToken}}

###

### Upsert tool blog
PUT {{baseUrl}}/admin/tools/qr-generator/blog
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "title": "QR Code Generator Guide",
  "excerpt": "How to create custom QR codes",
  "body": "<p>Full article HTML here.</p>",
  "status": "published",
  "metaTitle": "QR Code Generator | Dev Hube",
  "metaDescription": "Create custom QR codes with logos and colors"
}

###

### Delete tool blog
DELETE {{baseUrl}}/admin/tools/qr-generator/blog
Authorization: Bearer {{adminToken}}

###

### List all tool blogs (admin)
GET {{baseUrl}}/admin/tool-blogs
Authorization: Bearer {{adminToken}}

