  "value": {
    "name": "Dev Hube",
    "tagline": "The developer utility hub"
  }
}

###

### Update gallery
PATCH {{baseUrl}}/admin/settings/gallery
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "value": {
    "bend": 1,
    "scrollSpeed": 2,
    "scrollEase": 0.05
  }
}

###

### Update navigation
PATCH {{baseUrl}}/admin/settings/navigation
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "value": {
    "items": [
      {
        "id": "home",
        "label": "Home",
        "href": "/",
        "target": "_self",
        "sortOrder": 0,
        "enabled": true
      },
      {
        "id": "tools",
        "label": "Tools",
        "href": "/tools",
        "target": "_self",
        "sortOrder": 1,
        "enabled": true
      },
      {
        "id": "blog",
        "label": "Blog",
        "href": "/blog",
        "target": "_self",
        "sortOrder": 2,
        "enabled": true
      }
    ]
  }
}

