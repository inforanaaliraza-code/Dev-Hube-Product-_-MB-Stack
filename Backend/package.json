{
  "name": "dev-hube-backend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "prebuild": "pnpm install",
    "build": "nest build",
    "prestart": "pnpm install && pnpm run build",
    "start": "nest start",
    "prestart:dev": "pnpm install",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "seed": "ts-node -r dotenv/config -r tsconfig-paths/register src/database/seed.ts",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "migration:show": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:show",
    "migration:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate src/database/migrations/SchemaUpdate",
    "db:setup": "pnpm run migration:run && pnpm run seed",
    "db:reset-migrations": "ts-node -r dotenv/config -r tsconfig-paths/register src/database/reset-migrations.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm run typecheck && pnpm run lint",
    "audit:tools": "node ../scripts/audit-all-tools.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "marked": "^15.0.7",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "sql-formatter": "^15.4.11",
    "whoiser": "^1.8.0",
    "clean-css": "^5.3.3",
    "cron-parser": "^4.9.0",
    "diff": "^7.0.0",
    "js-beautify": "^1.15.4",
    "turndown": "^7.2.0",
    "ua-parser-js": "^2.0.0",
    "uuid": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/diff": "^7.0.0",
    "@types/js-beautify": "^1.14.3",
    "@types/turndown": "^5.0.5",
    "@types/ua-parser-js": "^0.7.39",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "eslint": "^9.32.0",
    "dotenv": "^16.4.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.38.0"
  }
}
